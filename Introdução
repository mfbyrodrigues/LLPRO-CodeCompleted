#include <stdio.h>

int main (){

    float distT, combgT, consuM;

	printf ("Insira a distância total percorrida, em KM: \n");
	scanf ("%f", &distT);
	printf ("E o total de combustível gasto, em L: \n");
	scanf ("%f", &combgT);

	consuM = (distT/combgT);
	printf ("O consumo médio do automóvel foi de: \n");
	printf ("%.0f KM/L.", consuM);

	return 0;
}
